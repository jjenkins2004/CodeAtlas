{
  "name": "code-atlas",
  "version": "0.1.0",
  "description": "Semantic symbol index for codebases, exposed via REST and MCP",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "start:mcp": "node dist/mcp/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.19.2",
    "pg": "^8.11.5",
    "pgvector": "^0.2.0",
    "tree-sitter": "^0.21.1",
    "uuid": "^9.0.1",
    "zod": "^3.23.8",
    "chokidar": "^3.6.0",
    "ignore": "^5.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "@types/uuid": "^9.0.8",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
