{
  "name": "code-atlas",
  "version": "0.1.0",
  "description": "Semantic symbol index for codebases, exposed via REST and MCP",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:ui": "npm run build && OPEN_UI=true node dist/index.js",
    "dev:all": "npm run dev:ui",
    "start": "node dist/index.js",
    "start:mcp": "node dist/mcp/index.js",
    "db:generate": "drizzle-kit generate",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chokidar": "^3.6.0",
    "drizzle-orm": "^0.45.2",
    "express": "^4.19.2",
    "ignore": "^5.3.1",
    "openai": "^4.104.0",
    "ollama": "^0.5.16",
    "pg": "^8.11.5",
    "pgvector": "^0.2.0",
    "tree-sitter": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-swift": "^0.7.1",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.11.5",
    "@types/uuid": "^9.0.8",
    "drizzle-kit": "^0.31.10",
    "pg-mem": "^3.0.14",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.5"
  }
}
